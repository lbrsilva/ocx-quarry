{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "mint",
	"name": "OCX Documentation",
	"colors": {
		"primary": "#0D9373",
		"light": "#07C983",
		"dark": "#0D9373"
	},
	"favicon": "/favicon.svg",
	"navigation": {
		"anchors": [
			{
				"anchor": "Documentation",
				"icon": "book-open",
				"groups": [
					{
						"group": "Getting Started",
						"pages": [
							"getting-started/introduction",
							"getting-started/installation",
							"getting-started/quick-start"
						]
					},
					{
						"group": "Profiles",
						"pages": [
							"profiles/overview",
							"profiles/configuration",
							"profiles/security",
							"profiles/ws",
							"profiles/omo"
						]
					},
					{
						"group": "CLI",
						"pages": [
							"cli/commands",
							"cli/init",
							"cli/add",
							"cli/remove",
							"cli/update",
							"cli/search",
							"cli/verify",
							"cli/registry",
							"cli/build",
							"cli/self",
							"cli/profile",
							"cli/config",
							"cli/opencode"
						]
					},
					{
						"group": "Registries",
						"pages": ["registries/create", "registries/protocol"]
					},
					{
						"group": "Reference",
						"pages": [
							"reference/opencode",
							"reference/plugins",
							"reference/configuration",
							"reference/agents",
							"reference/skills",
							"reference/tools",
							"reference/mcp",
							"reference/permissions"
						]
					},
					{
						"group": "Guides",
						"pages": ["guides/index", "guides/oh-my-opencode", "guides/kdco-workspace"]
					},
					{
						"group": "Integrations",
						"pages": [
							"integrations/workspace",
							"integrations/background-agents",
							"integrations/notify",
							"integrations/worktree"
						]
					},
					{
						"group": "Enterprise",
						"pages": ["enterprise/overview"]
					},
					{
						"group": "Security",
						"pages": ["security/policy", "security/verification"]
					}
				]
			}
		],
		"global": {
			"anchors": [
				{
					"anchor": "GitHub",
					"href": "https://github.com/kdcokenny/ocx",
					"icon": "github"
				},
				{
					"anchor": "npm",
					"href": "https://www.npmjs.com/package/ocx",
					"icon": "npm"
				}
			]
		}
	},
	"logo": {
		"light": "/logo/light.svg",
		"dark": "/logo/dark.svg"
	},
	"navbar": {
		"links": [
			{
				"label": "GitHub",
				"href": "https://github.com/kdcokenny/ocx"
			}
		],
		"primary": {
			"type": "button",
			"label": "Install",
			"href": "/getting-started/installation"
		}
	},
	"footer": {
		"socials": {
			"github": "https://github.com/kdcokenny/ocx"
		}
	},
	"redirects": [
		{
			"source": "/docs/CLI",
			"destination": "/cli/commands"
		},
		{
			"source": "/docs/PROFILES",
			"destination": "/profiles/overview"
		},
		{
			"source": "/docs/ENTERPRISE",
			"destination": "/enterprise/overview"
		},
		{
			"source": "/SECURITY",
			"destination": "/security/policy"
		},
		{
			"source": "/docs/MIGRATION-v1.4.0",
			"destination": "/maintainers/migration-v1-4-0"
		},
		{
			"source": "/docs/CREATING_REGISTRIES",
			"destination": "/registries/create"
		},
		{
			"source": "/docs/REGISTRY_PROTOCOL",
			"destination": "/registries/protocol"
		},
		{
			"source": "/docs/OPENCODE_REFERENCE",
			"destination": "/reference/opencode"
		},
		{
			"source": "/docs/guides",
			"destination": "/guides/index"
		},
		{
			"source": "/docs/guides/oh-my-opencode",
			"destination": "/guides/oh-my-opencode"
		},
		{
			"source": "/docs/guides/kdco-workspace",
			"destination": "/guides/kdco-workspace"
		}
	]
}
